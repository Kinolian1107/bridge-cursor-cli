# cursor-bridge configuration
# Copy this to .env and adjust as needed

# Port for the bridge proxy server
BRIDGE_PORT=18790

# Cursor CLI model to use (run: cursor agent --list-models)
# Popular choices:
#   opus-4.6-thinking     — Claude 4.6 Opus with Thinking (recommended)
#   opus-4.6              — Claude 4.6 Opus
#   sonnet-4.6-thinking   — Claude 4.6 Sonnet with Thinking
#   gpt-5.2-codex-high    — GPT-5.2 Codex High
#   gemini-3-pro          — Gemini 3 Pro
CURSOR_MODEL=opus-4.6-thinking

# Path to cursor-agent binary or cursor wrapper
# CURSOR_BIN=/home/you/.local/bin/cursor-agent
# CURSOR_BIN=cursor

# Workspace path for cursor agent
# CURSOR_WORKSPACE=/home/you/.cursor-bridge/workspace

# Agent mode: '' (full agent), 'ask' (read-only Q&A), 'plan' (read-only planning)
# CURSOR_MODE=ask

# Cursor authentication (alternative to `cursor agent login`)
# One of these is required if not already logged in via the CLI
# CURSOR_API_KEY=your-api-key-here
# CURSOR_AUTH_TOKEN=your-auth-token-here

# Use git worktree isolation (edits made in a temporary worktree under ~/.cursor/worktrees)
# CURSOR_WORKTREE=true

# Request timeout in milliseconds (default: 5 minutes)
# BRIDGE_TIMEOUT_MS=300000
